    "onboarding.organization.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Record a bar, a coin or a piece of jewellery. Kara turns every detail into a clear, living inventory."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez un lingot, une pièce ou un bijou. Kara transforme chaque détail en un inventaire clair et vivant."
          }
        }
      }
    },
    "onboarding.organization.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
